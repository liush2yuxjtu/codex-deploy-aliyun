# Local secrets — never commit
.env
.env.local
.env.*.local

# Node
node_modules/
npm-debug.log*
yarn-error.log
*.log

# OS junk
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Worktrees / test artifacts
.playwright-mcp/
workspace/pdf-*.png
workspace/pdf-ui*.png
workspace/work/          # md-to-pdf-webfirst scratch workdirs (chrome-profile, etc.)
workspace/fixtures/      # anonymized test fixtures (see ISSUE-008)
workspace/**/chrome-profile/
workspace/**/Default/
workspace/**/*.pdf.png
/tmp/codex-pdf-out/
/tmp/codex-pdf-up/

# Server-side scratch (mirror what's on /opt/codex-api/ but never source-controlled)
*.bak
server.js.bak.*
secret.env

# Credential rotation backups — written by scripts/rotate_credentials.sh
# (never commit; outside the repo by default but listed for safety)
~/.credentials.bak/
