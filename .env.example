# codex-deploy-aliyun — environment template
# Copy to .env and fill in real values. NEVER commit .env (gitignored).
# Source before running scripts:  set -a; . ./.env; set +a
#
# Real values for LLM_API_KEY / RDS_PASSWORD / ALIBABA_CLOUD_ACCESS_KEY_* /
# SSH_KEY are produced by `scripts/rotate_credentials.sh --only <llm|rds|ak|ssh>
# --apply` — do NOT hand-edit them in this file. The script also writes a
# backup to ~/.credentials.bak/<ts>/ and pushes the updated file to the
# server's /etc/codex-api/secret.env. Default mode is --dry-run.

# ─── Aliyun RAM credentials (needs AliyunSWASFullAccess + AliyunRDSFullAccess) ───
ALIBABA_CLOUD_ACCESS_KEY_ID=LTAIxxxxxxxxxxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CLI defaults
ALIYUN_PROFILE=myaliyun
ALIYUN_REGION=cn-shanghai

# ─── SWAS (the demo server) ───
SWAS_INSTANCE_ID=i-xxxxxxxxxxxxxxxxxxxx
SWAS_REGION=cn-shanghai
SERVER_IP=1.2.3.4
SERVER_HOSTNAME=your-host.sslip.io
SSH_KEY=~/.ssh/aliyun_deploy

# ─── RDS PostgreSQL (history persistence) ───
RDS_INSTANCE_ID=pgm-xxxxxxxxxxxx
RDS_REGION=cn-hangzhou
RDS_INTRANET=pgm-xxxxxxxxxxxx.pg.rds.aliyuncs.com
RDS_PUBLIC=xxxx-pgm-xxxxxxxxxxxx.pg.rds.aliyuncs.com
RDS_PORT=5432
RDS_DB=codex_demo
RDS_ADMIN=codex_admin
RDS_PASSWORD=replace-with-24-char-random

# ─── LLM gateway (used by codex-api server.js, sourced from /etc/codex-api/secret.env on the box) ───
LLM_API_KEY=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://code.newcli.com/codex/v1
LLM_DEFAULT_MODEL=claude-fable-5

# ─── Codex API server (read by frontend / curl) ───
CODEX_API_ENDPOINT=http://1.2.3.4:3030
DEMO_SECRET=

# ─── md-to-pdf-webfirst skill (optional, /pdf endpoint) ───
PDF_SKILL_DIR=~/.codex/skills/md-to-pdf-webfirst
PDF_OUTPUT_DIR=/tmp/codex-pdf-out

# ─── Aliyun OSS (ISSUE-022: PDF outputs land here) ───
# When all four OSS_* values are set, /pdf and /pdf/upload upload the
# generated PDF here and return a 1h presigned GET URL (JSON body) instead
# of streaming 1MB+ through the SWAS egress. On any failure we silently
# fall back to the v1 binary stream — clients never see an error.
#
# Provision the bucket + private ACL with:
#   bash scripts/setup_oss_bucket.sh --dry-run   # print the plan
#   bash scripts/setup_oss_bucket.sh             # apply
#
# RAM policy the codexsbx user needs on the bucket:
#   - oss:PutObject  on  acs:oss:*:codex-deploy-aliyun-pdf-out/pdfs/*
#   - oss:GetObject  on  acs:oss:*:codex-deploy-aliyun-pdf-out/pdfs/*   (re-presign)
#   NO public-read grant — the bucket is private; downloads go via presign.
OSS_BUCKET=codex-deploy-aliyun-pdf-out
OSS_REGION=cn-shanghai
OSS_ACCESS_KEY_ID=LTAIxxxxxxxxxxxx
OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OSS_PRESIGN_TTL_SEC=3600

# ─── Aliyun SLS (ISSUE-024 structured logging) ───
# When all five are set, codex-api ships a structured copy of every
# operationally meaningful log line (request entry, job start/done/error,
# persistence failures) to SLS in addition to stdout. Leave blank to
# keep stdout-only behaviour. The AK/SECRET pair is typically the
# codexsbx RAM user with the custom `SlsPutLogLines-<project>-<logstore>`
# policy (created by `scripts/setup_sls_logstore.sh --ram-user codexsbx
# --policy-put`). Do NOT reuse the SWAS admin AK here.
SLS_ENDPOINT=cn-shanghai.log.aliyuncs.com
SLS_PROJECT=codex-deploy-aliyun
SLS_LOGSTORE=codex-api
SLS_ACCESS_KEY_ID=
SLS_ACCESS_KEY_SECRET=
# Optional tunables
# SLS_TOPIC=codex-api
# SLS_FLUSH_MAX=50
# SLS_FLUSH_MS=1000
